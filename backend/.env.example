PORT=3001
FRONTEND_URL=http://localhost:5173

# MongoDB — leave unset to auto-start an in-memory DB (no install needed)
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/aragon_upload

# AWS S3 — leave unset to store files on local disk under backend/uploads/
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=

# Validation thresholds (optional — these are the defaults)
# MIN_IMAGE_WIDTH=200
# MIN_IMAGE_HEIGHT=200
# MIN_FILE_BYTES=10000
# BLUR_THRESHOLD=500
# SIMILARITY_THRESHOLD=10
# MIN_FACE_SIZE_RATIO=0.05
